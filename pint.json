{
    "preset": "laravel",
    "rules": {
        "single_trait_insert_per_statement": true,
        "new_with_braces": {
            "anonymous_class": false,
            "named_class": false
        },
        "explicit_string_variable": true,
        "yoda_style": {
            "always_move_variable": true,
            "equal": true
        }
    },
    "exclude": [
        "tests/Fixtures"
    ]
}
